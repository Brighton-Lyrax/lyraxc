# =============================================================================
# Lyraxc environment configuration
# Copy this file to `.env` and adjust the values. Never commit `.env`.
# =============================================================================

# --- HTTP server ---
# Port the API/WebSocket server listens on.
PORT=3000
# Host to bind to. Use 0.0.0.0 inside containers.
HOST=127.0.0.1
# Comma-separated list of allowed CORS origins. Use * only for local dev.
CORS_ORIGINS=http://localhost:5173
# Optional bearer token required by the API. Leave empty to disable auth (dev only).
API_KEY=

# --- Logging ---
# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Pretty-print logs (true for local dev, false for JSON logs in production).
LOG_PRETTY=true

# --- Browser (Playwright) ---
# Run the browser without a visible window (true in servers/CI).
BROWSER_HEADLESS=true
# Slow down each Playwright operation by N ms (helps observe automation).
BROWSER_SLOW_MO=0
# Default navigation/action timeout in milliseconds.
BROWSER_TIMEOUT_MS=30000
# Viewport size.
BROWSER_VIEWPORT_WIDTH=1366
BROWSER_VIEWPORT_HEIGHT=768
# Optional custom User-Agent. Leave empty to use Playwright's default.
BROWSER_USER_AGENT=
# Optional persistent user-data directory for cookies/sessions.
BROWSER_USER_DATA_DIR=

# --- Human-like behaviour ---
# Enable randomized delays, mouse movement and typing jitter.
HUMANIZE_ENABLED=true
# Base per-character typing delay range (ms).
HUMANIZE_TYPING_MIN_MS=45
HUMANIZE_TYPING_MAX_MS=140
# Random "think time" between actions (ms).
HUMANIZE_ACTION_MIN_MS=350
HUMANIZE_ACTION_MAX_MS=1200

# --- LLM (OpenAI-compatible) ---
# Provider: openai | mock. `mock` uses a deterministic offline planner.
LLM_PROVIDER=mock
# Base URL for an OpenAI-compatible API.
LLM_BASE_URL=https://api.openai.com/v1
# API key for the LLM provider.
LLM_API_KEY=
# Model name.
LLM_MODEL=gpt-4o-mini
# Sampling temperature.
LLM_TEMPERATURE=0.2
# Max steps the agent may take for a single task.
AGENT_MAX_STEPS=25

# --- Safety ---
# Comma-separated allow-list of domains the agent may visit. Empty = allow all.
ALLOWED_DOMAINS=
# Comma-separated block-list of domains the agent must never visit.
BLOCKED_DOMAINS=
